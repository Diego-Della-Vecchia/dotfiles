# See https://git-scm.com/docs/git-config

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[init]
	defaultBranch = main
[pull]
	rebase = true 			 
[push]
	autoSetupRemote = true   
[diff]
	algorithm = histogram   
	colorMoved = plain     
	mnemonicPrefix = true 
[commit]
	verbose = true           
[column]
	ui = auto 			     
[branch]
	sort = -committerdate    
[tag]
	sort = -version:refname  
[rerere]
	enabled = true           
	autoupdate = true       
[user]
	name = Diego Della Vecchia
	email = diego.dellavecchia3@gmail.com
[core]
	editor = nvim
