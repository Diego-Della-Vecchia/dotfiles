[
  {
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },

  {
    "context": "Editor",
    "bindings": {
      // Leader-style key binds
      "space c a": "editor::ToggleCodeActions",
      "space r n": "editor::Rename",
      "space f f": "file_finder::Toggle",
      "space f g": "pane::DeploySearch",

      "shift k": "editor::Hover",

      "g d": "editor::GoToDefinitionSplit",
      "g r": "editor::FindAllReferences",
    },
  },

  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "up": "editor::ContextMenuPrevious",
      "ctrl-k": "editor::ContextMenuPrevious",
      "down": "editor::ContextMenuNext",
      "ctrl-j": "editor::ContextMenuNext",
      "pageup": "editor::ContextMenuFirst",
      "pagedown": "editor::ContextMenuLast",
    },
  },

  {
    "context": "Workspace",
    "bindings": {
      "space e t": "project_panel::Toggle",
      "space e f": "project_panel::ToggleFocus",

      "space g t": "git_panel::Toggle",
      "space g f": "git_panel::ToggleFocus",

      "space t t": "terminal_panel::Toggle",
      "space t f": "terminal_panel::ToggleFocus",

      "space a t": "agent::Toggle",
      "space a f": "agent::ToggleFocus",

      "space d d": "workspace::CloseActiveDock",

      "space s h": "workspace::NewFileSplitVertical",
      "space s v": "workspace::NewFileSplitHorizontal",
    },
  },
]
