{
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Frappé",
  },
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 18,

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 18,
  "buffer_font_features": {
    "calt": false, // Disables font ligatures
  },
  "vim_mode": true,
  "scrollbar": {
    "show": "never",
  },
  "indent_guides": {
    "enabled": false,
  },

  "title_bar": {
    "show_menus": false,
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },

  // --- Panels & Sidebars ---
  "project_panel": {
    "dock": "right",
    "default_width": 300,
    "indent_size": 30,
    "entry_spacing": "comfortable",
    "bold_folder_labels": true,
    "git_status": true,
    "show_diagnostics": "errors",
    "hide_hidden": true,
    "hide_root": false,
    "indent_guides": {
      "show": "never",
    },
  },

  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry",
    },
  },
}
